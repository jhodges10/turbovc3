{
  "name": "@jhodges10/turbovc3",
  "version": "0.1.0",
  "description": "DNxHD/DNxHR decoding and MXF demuxing for browsers",
  "keywords": [
    "dnxhd",
    "dnxhr",
    "vc-3",
    "video-codec",
    "webassembly",
    "webgpu",
    "mxf",
    "mediabunny"
  ],
  "homepage": "https://github.com/jhodges10/turbovc3#readme",
  "bugs": "https://github.com/jhodges10/turbovc3/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jhodges10/turbovc3.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mxf": {
      "types": "./dist/mxf/index.d.ts",
      "import": "./dist/mxf/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js"
    }
  },
  "files": [
    "README.md",
    "LICENSE",
    "docs/deployment.md",
    "dist",
    "wasm/generated/*.wasm"
  ],
  "license": "MPL-2.0",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "prepack": "npm run build",
    "check": "tsc --noEmit -p tsconfig.json",
    "api:report": "npm run build && api-extractor run && api-extractor run --config api-extractor.mxf.json && api-extractor run --config api-extractor.node.json",
    "api:report:update": "npm run build && api-extractor run --local && api-extractor run --local --config api-extractor.mxf.json && api-extractor run --local --config api-extractor.node.json",
    "build:wasm-kernel": "bash scripts/build-dnx-wasm.sh",
    "build:zig-wasm": "bash scripts/build-dnx-zig-wasm.sh",
    "build:wasm": "npm run build:wasm-kernel && npm run build:zig-wasm",
    "fixtures:generate": "node tests/dnx-oracle-test.mjs --generate --allow-missing",
    "fixtures:verify": "node tests/committed-fixtures-test.mjs",
    "test": "npm run test:unit && npm run test:fixtures",
    "test:unit": "node tests/dnx-pixel-conversion-test.mjs && node tests/dnx-canvas-renderer-test.mjs && node tests/dnx-webgpu-renderer-test.mjs && node tests/dnx-decoder-contract-test.mjs && node tests/dnx-playback-clock-test.mjs && node tests/dnx-audio-playback-test.mjs && node tests/dnx-malformed-test.mjs && node tests/mxf-demuxer-test.mjs && node tests/mediabunny-compat-test.mjs && node tests/fuzz-smoke-test.mjs",
    "test:fuzz": "node tests/fuzz-smoke-test.mjs --iterations 256",
    "test:fixtures": "node tests/committed-fixtures-test.mjs",
    "test:extended": "node tests/dnx-oracle-test.mjs --allow-missing",
    "test:browser": "playwright test",
    "test:runtimes": "deno run --allow-read tests/runtime-worker-smoke.mjs && bun tests/runtime-worker-smoke.mjs",
    "test:native": "node tests/dnx-wasm-kernel-test.mjs && node tests/committed-fixtures-test.mjs --require-native",
    "test:package": "node tests/package-smoke-test.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "mediabunny": "^1.50.8"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "7.58.11",
    "@playwright/test": "1.61.1",
    "@types/node": "^26.1.0",
    "esbuild": "^0.28.1",
    "mediabunny": "1.50.8",
    "typescript": "^7.0.2"
  }
}
